# Copy this file to .env.local and fill in the values from your Supabase
# project settings (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: used as a fallback when constructing email confirmation redirect
# links from a context where an Origin header isn't available. Set this to
# your deployed URL in Vercel's environment variables. Also used by the
# proxy (src/proxy.ts) to tell platform traffic apart from community custom
# domains, so keep it pointing at the platform's own URL — never at a
# community's domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for email invites (admin -> "Invite by email") and for community
# custom domains (admin -> "Custom domain"). Find it in
# Project Settings -> API -> Project API keys -> service_role.
# NEVER prefix this with NEXT_PUBLIC_ and never commit a real value — it
# bypasses Row Level Security entirely. Only read server-side (see
# src/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: powers the AI-synthesized answer on the Concierge page (see
# src/lib/ai/concierge-answer.ts) and staff-facing AI event discovery on the
# Events page (see src/lib/ai/discover-events.ts). Without it, Concierge
# still works — it just shows Layer 1's plain grouped search results with no
# summary — and event discovery reports itself as unavailable.
# Get a key at https://console.anthropic.com/settings/keys. Server-side only.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: lets "Check verification" on the community admin page also
# register the custom domain with the Vercel project automatically (routing
# + SSL), making domain setup fully self-serve — see src/lib/vercel-domains.ts.
# Without these, the platform operator adds each domain by hand in
# Vercel -> Settings -> Domains. Create the token at
# https://vercel.com/account/tokens; the project ID is in the Vercel
# project's Settings -> General. VERCEL_TEAM_ID only if the project lives in
# a team. All server-side only.
# VERCEL_TOKEN=your-vercel-api-token
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxx
# VERCEL_TEAM_ID=team_xxxxxxxxxxxx

# Optional: sends community-branded invite emails through Resend
# (see src/lib/email.ts) — "You're invited to Mzungu Zanzibar", from the
# community's name, with its logo, and without pre-creating a passwordless
# auth account the way Supabase's inviteUserByEmail does. Without it, email
# invites fall back to Supabase Auth's global "from Relate" template.
# Requires the sending domain to be verified in Resend (resend.com ->
# Domains). INVITE_EMAIL_FROM defaults to invites@<NEXT_PUBLIC_SITE_URL
# hostname>. Both server-side only.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# INVITE_EMAIL_FROM=invites@relate.click

# Optional: shows each business's live Google rating and review snippets in
# the map pin popup (see src/lib/google-places.ts). Needs "Places API (New)"
# enabled on the key in Google Cloud Console. Without it, popups still work —
# they just skip the Google section. Server-side only.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

