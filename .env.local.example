# Copy this file to .env.local and fill in the values from your Supabase
# project settings (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: used as a fallback when constructing email confirmation redirect
# links from a context where an Origin header isn't available. Set this to
# your deployed URL in Vercel's environment variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required only for email invites (admin -> "Invite by email"). Find it in
# Project Settings -> API -> Project API keys -> service_role.
# NEVER prefix this with NEXT_PUBLIC_ and never commit a real value — it
# bypasses Row Level Security entirely. Only read server-side (see
# src/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: powers the AI-synthesized answer on the Concierge page (see
# src/lib/ai/concierge-answer.ts) and staff-facing AI event discovery on the
# Events page (see src/lib/ai/discover-events.ts). Without it, Concierge
# still works — it just shows Layer 1's plain grouped search results with no
# summary — and event discovery reports itself as unavailable.
# Get a key at https://console.anthropic.com/settings/keys. Server-side only.
ANTHROPIC_API_KEY=your-anthropic-api-key

